{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && npx --yes pnpm@10 install --frozen-lockfile",
  "buildCommand": "cd frontend && npx --yes pnpm@10 run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
